# Streaming mode: set to "direct" to use built-in @consumet/extensions (no separate server).
# Or point to a Consumet-compatible HTTP API base URL to swap providers later.
NEXT_PUBLIC_STREAM_API_URL=direct

# Provider path for remote API mode, or direct provider hint (hianime / animepahe / animekai)
NEXT_PUBLIC_STREAM_PROVIDER=anime/hianime

# Optional: stream resolution timeout in ms (default 15000)
STREAM_FETCH_TIMEOUT_MS=15000
